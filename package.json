{
  "name": "carrying-quota",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build:tokens && tsc -b && vite build",
    "build:tokens": "npm run build --workspace=@cq/tokens",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src packages",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "npm run build:tokens && storybook build",
    "test:a11y": "node tests/a11y.mjs",
    "test:visual": "playwright test --config=tests/visual.config.ts"
  },
  "dependencies": {
    "@cq/tokens": "*",
    "@cq/ui": "*",
    "@tanstack/react-query": "^5.62.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "motion": "^11.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.15.1",
    "tailwind-merge": "^2.5.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@chromatic-com/storybook": "^3.2.6",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@storybook/addon-a11y": "^8.6.12",
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/blocks": "^8.6.12",
    "@storybook/react": "^8.6.12",
    "@storybook/react-vite": "^8.6.12",
    "@storybook/test": "^8.6.12",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/parser": "^8.18.2",
    "@typescript-eslint/utils": "^8.18.2",
    "@vitejs/plugin-react": "^4.3.4",
    "axe-core": "^4.10.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "playwright": "^1.49.1",
    "storybook": "^8.6.12",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.0"
  }
}
