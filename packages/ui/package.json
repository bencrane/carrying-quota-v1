{
  "name": "@cq/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Carrying Quota — token-typed UI primitive package. Layout, page, editorial, display, typography, and motion primitives plus the reference interactive data figure. Pure source consumed by Vite; no build step.",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": ["src"],
  "dependencies": {
    "@cq/tokens": "*",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.5"
  },
  "peerDependencies": {
    "motion": "^11.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.15.1"
  }
}
